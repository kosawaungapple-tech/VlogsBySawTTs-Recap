rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: uid
    // Fields:
    //   - accessCode: string
    //   - createdAt: string
    //
    // Collection: users
    // Document ID: accessCode
    // Fields:
    //   - id: string
    //   - label: string
    //   - isActive: boolean
    //   - role: string ("admin" | "user")
    //   - api_key_stored: string (optional)
    //   - createdAt: string
    //   - createdBy: string
    //
    // Collection: history
    // Document ID: auto
    // Fields:
    //   - userId: string (matches accessCode)
    //   - text: string
    //   - audioStorageUrl: string
    //   - srtStorageUrl: string
    //   - createdAt: string
    //   - config: map
    //
    // Collection: globalRules
    // Document ID: auto
    // Fields:
    //   - original: string
    //   - replacement: string
    //   - isRegex: boolean
    //   - isActive: boolean
    //
    // Collection: settings
    // Document ID: "global"
    // Fields:
    //   - allow_global_key: boolean
    //   - total_generations: number
    //
    // Collection: config
    // Document ID: "system_config"
    // Fields:
    //   - gemini_api_key: string
    //   - rapidapi_key: string
    //   - openai_api_key: string
    //   - system_live: boolean
    //   - telegram_bot_token: string
    //   - telegram_chat_id: string
    // ===============================================================

    // ===============================================================
    // Devil's Advocate Attack Documentation
    // ===============================================================
    // 1. Public List Exploit: FAILED. Default deny on all collections.
    // 2. Unauthorized Read/Write: FAILED. Checks for isDocOwner() or isAdmin().
    // 3. The "Update Bypass": FAILED. update rules call isValidX() functions.
    // 4. Ownership Hijacking: FAILED. uidUnchanged() and uidNotModified() checks.
    // 5. Immutable Field Modification: FAILED. resource.data.userId == request.resource.data.userId checks.
    // 6. Data Corruption: FAILED. Type checks (is string, is bool) in validation functions.
    // 7. Privilege Escalation: FAILED. role is validated and only admins can change roles.
    // 8. Resource Exhaustion: FAILED. .size() checks on strings.
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getAccessCode() {
      return exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode 
        : null;
    }

    function isAdmin() {
      let accessCode = getAccessCode();
      return isAuthenticated() && (
        (accessCode != null && (
          accessCode == 'saw_vlogs_2026' ||
          (exists(/databases/$(database)/documents/users/$(accessCode)) &&
           get(/databases/$(database)/documents/users/$(accessCode)).data.role == 'admin')
        )) ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "kosawaung.apple@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isDocOwner() {
      let accessCode = getAccessCode();
      return isAuthenticated() && accessCode != null && resource.data.userId == accessCode;
    }

    function isValidAuthorizedUser(data) {
      return data.keys().hasAll(['id', 'isActive', 'role']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.isActive is bool &&
             data.role in ['admin', 'user'];
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['userId', 'text', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.text is string && data.text.size() <= 50000 &&
             data.createdAt is string;
    }

    function isValidPronunciationRule(data) {
      return data.keys().hasAll(['original', 'replacement']) &&
             data.original is string && data.original.size() > 0 && data.original.size() < 500 &&
             data.replacement is string && data.replacement.size() < 500;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['accessCode', 'createdAt']) &&
             data.accessCode is string && data.accessCode.size() > 0 && data.accessCode.size() < 100 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sessions/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == uid && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    match /users/{accessCode} {
      // Anyone authenticated can try to get a specific access code to log in
      allow get: if isAuthenticated();
      // Only admins can list all users
      allow list: if isAdmin();
      
      // Admins can create new users, or anyone can bootstrap the default admin once
      allow create: if (isAuthenticated() && (isAdmin() || (accessCode == 'SAW-ADMIN-2026'))) && isValidAuthorizedUser(request.resource.data);
      
      // Users can update their own API key, but cannot change their role or ID
      allow update: if isAuthenticated() && isValidAuthorizedUser(request.resource.data) && (
        isAdmin() || 
        (
          getAccessCode() == accessCode &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.id == resource.data.id &&
          (!('api_key_stored' in request.resource.data) || request.resource.data.api_key_stored is string)
        )
      );
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      // Users can read their own history, admins can read all
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      
      // Users can create their own history
      allow create: if isAuthenticated() && isValidHistoryItem(request.resource.data) && request.resource.data.userId == getAccessCode();
      
      // Users can update/delete their own history, admins can update/delete all
      allow update: if isAuthenticated() && isValidHistoryItem(request.resource.data) && (isDocOwner() || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /globalRules/{ruleId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidPronunciationRule(request.resource.data);
      allow update: if isAdmin() && isValidPronunciationRule(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config/system_config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_config/system_config {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /profiles/{userId} {
      // Used for Google Auth admins
      allow read, write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true; // Used for connection testing
      allow write: if false;
    }
  }
}
